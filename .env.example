# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- GCP (detection training) ---
PROJECT_ID=your-gcp-project-id
REGION=us-central1
ZONE=us-central1-a
BUCKET=gs://your-gcp-project-id-sku110k-yolo

# Dataset cache — pre-downloaded datasets (SKU-110K, COCO 2017, RPC, ...).
# See datasets/README.md. Created via datasets/setup_bucket.sh.
DATASETS_BUCKET=gs://your-gcp-project-id-datasets

# --- Backend (Module 4) ---
API_KEY=change-me-dev-api-key
DATABASE_URL=sqlite:///./inventory.db

# --- BI interface (Module 5) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
