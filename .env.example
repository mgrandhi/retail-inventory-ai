# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- GCP (detection training) ---
PROJECT_ID=your-gcp-project-id
REGION=us-central1
ZONE=us-central1-a
BUCKET=gs://your-gcp-project-id-sku110k-yolo

# Dataset cache — pre-downloaded datasets (SKU-110K, COCO 2017, RPC, ...).
# See datasets/README.md. Created via datasets/setup_bucket.sh.
DATASETS_BUCKET=gs://your-gcp-project-id-datasets

# --- Classification labeling (Module 2) — GCP VLM via Vertex AI ---
# No API key: auth is the VM service account (grant roles/aiplatform.user). Verify the exact
# model id against the live Model Garden before a big run (ids version fast).
VERTEX_MODEL=gemini-2.5-flash

# --- ShelfSight server-side AI providers ---
# The browser receives only provider/model names and availability. Never expose these credentials
# through Vite variables or client request payloads.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODELS=gemini-2.5-flash
SKU_PROVIDER=gemini

# OpenRouter is optional. Keep the API key only in the server/VM environment.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_MODELS=google/gemini-2.5-flash
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=ShelfSight
LLM_TIMEOUT_SECONDS=60

# --- Backend (Module 4) ---
API_KEY=change-me-dev-api-key
DATABASE_URL=sqlite:///./inventory.db

# --- BI interface (Module 5) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
