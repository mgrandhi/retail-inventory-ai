# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.ipynb_checkpoints/

# Secrets / env
.env
*.key
*-key.json
service-account*.json

# Data & model artifacts (large; live on VM / GCS / Colab)
data/
*.pt
*.onnx
*.npy
runs/
detection/results/
detection/metrics.json

# ...except the per-variant checkpoint artifacts the Colab notebook needs to
# reproduce the before/after demo without any GCS dependency.
# Pattern: detection/artifacts/<variant>/{best.pt, metrics.json, results.png}.
!detection/artifacts/
!detection/artifacts/**/
!detection/artifacts/**/best.pt
!detection/artifacts/**/metrics.json
!detection/artifacts/**/results.png

# Datasets auto-downloaded by Ultralytics
datasets/

# LaTeX build artifacts
report/*.aux
report/*.log
report/*.out
report/*.toc
report/*.bbl
report/*.blg
report/*.fls
report/*.fdb_latexmk
report/*.synctex.gz
report/main.pdf

