# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.ipynb_checkpoints/

# Secrets / env
.env
*.key
*-key.json
service-account*.json

# Data & model artifacts (large; live on VM / GCS / Colab)
data/
*.pt
*.onnx
*.npy
runs/
detection/results/
detection/metrics.json

# ...except the per-variant checkpoint artifacts the Colab notebook needs to
# reproduce the before/after demo without any GCS dependency.
# Pattern: detection/artifacts/<variant>/{best.pt, metrics.json, results.png}.
!detection/artifacts/
!detection/artifacts/**/
!detection/artifacts/**/best.pt
!detection/artifacts/**/metrics.json
!detection/artifacts/**/results.png

# Module 2 generated outputs (large / reproducible; live on GCS).
# Generated label CSVs + usage logs from the autolabelers, and gated-inference predictions.
autolabel/labels_*.csv
autolabel/*.usage.json
autolabel/label_agreement_report.md
classification/preds*.csv

# ...but DO commit the chosen Gemini teacher-label CSVs (small; the notebook + training reference
# them, and the teammate wants them in the repo). The rejected CLIP labels stay out (GCS only).
!classification/labels/
!classification/labels/labels_gemini_*.csv

# ...except the per-variant classifier artifacts the Module-2 notebook needs to reproduce the
# results/inference demo without any GCS dependency. The big classifier.pt is tracked via Git LFS
# (see .gitattributes); the small JSON/log files commit normally. Mirrors detection/artifacts/.
!classification/artifacts/
!classification/artifacts/**/
!classification/artifacts/**/classifier.pt
!classification/artifacts/**/label_maps.json
!classification/artifacts/**/metrics.json
!classification/artifacts/**/gate_sweep.json
!classification/artifacts/**/train.log
!classification/artifacts/**/gate.log

# Datasets auto-downloaded locally for one-off testing.
# (datasets/ in the repo holds infra scripts only; never raw data.)
datasets/cache/
datasets/extracted/
datasets/*.tar.gz
datasets/*.zip

# LaTeX build artifacts
report/*.aux
report/*.log
report/*.out
report/*.toc
report/*.bbl
report/*.blg
report/*.fls
report/*.fdb_latexmk
report/*.synctex.gz
report/main.pdf

# OS
.DS_Store

# IDE / editor / agent local
.claude/
.cursor/
.idea/
.vscode/
